{
  "name": "naikaku-ai-togo-system",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "gateway": "tsx server/gateway.ts",
    "rehearsal": "tsx scripts/rehearsal.ts",
    "rehearsal:strict": "tsx scripts/rehearsal.ts --strict",
    "rehearsal:drill": "tsx scripts/release-drill-fixtures.ts --out output/release-drill && tsx scripts/rehearsal.ts --strict --workspace output/release-drill/workspace.json --run output/release-drill/run.json --provider-readiness output/release-drill/provider-readiness.json --approvals output/release-drill/approvals.json --audit output/release-drill/audit.json --memory output/release-drill/memory.json --saved-items output/release-drill/saved-items.json --secret-probe DRILL_REDACTION_PROBE --out output/rehearsal-drill",
    "coding-agent:dispatch": "tsx scripts/coding-agent-dispatch-drill.ts --out output/coding-agent-dispatch-drill",
    "coding-agent:simulate": "tsx scripts/coding-agent-dispatch-simulation.ts --out output/coding-agent-dispatch-simulation",
    "coding-agent:runner-manifest": "tsx scripts/coding-agent-runner-manifest.ts --simulation-dir output/coding-agent-dispatch-simulation --out output/coding-agent-runner-manifest",
    "coding-agent:runner-invocation": "tsx scripts/coding-agent-runner-invocation.ts --manifest-dir output/coding-agent-runner-manifest --out output/coding-agent-runner-invocation",
    "coding-agent:runner-intake": "tsx scripts/coding-agent-runner-intake-audit.ts --invocation-dir output/coding-agent-runner-invocation --out output/coding-agent-runner-intake-audit",
    "coding-agent:runner-self-test": "tsx scripts/coding-agent-runner-self-test.ts --manifest-dir output/coding-agent-runner-manifest --out output/coding-agent-runner-self-test",
    "coding-agent:runner-lease": "tsx scripts/coding-agent-runner-lease-drill.ts --self-test-dir output/coding-agent-runner-self-test --out output/coding-agent-runner-lease",
    "coding-agent:sandbox-runner": "tsx scripts/coding-agent-sandbox-runner-drill.ts --self-test-dir output/coding-agent-runner-self-test --out output/coding-agent-sandbox-runner",
    "coding-agent:gateway-smoke": "tsx scripts/coding-agent-gateway-runner-smoke.ts --out output/coding-agent-gateway-runner-smoke",
    "coding-agent:engineering-sim": "tsx scripts/coding-agent-engineering-self-simulation.ts --out output/coding-agent-engineering-self-simulation",
    "engineering:adapter-self-test": "tsx scripts/engineering-adapter-self-test.ts --out output/engineering-adapter-self-test",
    "engineering:adapters": "tsx scripts/engineering-adapters.ts --out output/engineering-adapters",
    "engineering:auto-work": "tsx scripts/engineering-auto-work.ts",
    "engineering:guided": "tsx scripts/guided-engineering-cycle.ts",
    "naikaku:task": "tsx scripts/naikaku-task.ts",
    "engineering:auto-work-gateway-smoke": "tsx scripts/engineering-auto-work-gateway-smoke.ts --out output/engineering-auto-work-gateway-smoke",
    "engineering:auto-work-smoke": "npm run engineering:auto-work -- --mission \"Open-source smoke: run one external CLI adapter and import its receipt\" --locale zh-Hans --out output/engineering-auto-work --runner-preset fixture --timeout-ms 60000 --generated-at 2026-06-27T00:00:00.000Z",
    "engineering:guided-smoke": "npm run engineering:guided -- --mission \"Open-source smoke: run a bounded cabinet loop through a fixed fixture runner\" --max-loops 3 --runner-preset fixture --adapter-ready --out output/engineering-guided-smoke --generated-at 2026-06-27T00:00:00.000Z --timeout-ms 60000",
    "open-source:mvp-check": "tsx scripts/open-source-mvp-check.ts",
    "engineering:runner-kit": "tsx scripts/engineering-runner-kit.ts",
    "local-tools:smoke": "tsx scripts/local-tool-smoke.ts",
    "cabinet:codex-smoke": "tsx scripts/cabinet-codex-role-smoke.ts",
    "cabinet:api-role-smoke": "tsx scripts/cabinet-api-role-smoke.ts",
    "cabinet:api-role-smoke:mock": "npm run cabinet:api-role-smoke -- --mock --mission \"Open-source smoke: separate provider roles produce proposal, critique, supervision, and a cabinet vote\" --out output/cabinet-api-role-smoke --generated-at 2026-06-27T00:00:00.000Z",
    "codex:engineer-smoke": "tsx scripts/codex-engineer-smoke.ts",
    "engineering:handoff": "tsx scripts/engineering-handoff.ts --input output/engineering-simulate --out output/engineering-handoff",
    "engineering:mvp": "tsx scripts/engineering-mvp.ts --out output/engineering-mvp",
    "engineering:review-adapter-run": "tsx scripts/engineering-review-adapter-run.ts",
    "engineering:run-adapter": "tsx scripts/engineering-run-adapter.ts --handoff output/engineering-handoff --out output/engineering-adapter-run",
    "engineering:simulate": "tsx scripts/engineering-simulate.ts --out output/engineering-simulate",
    "engineering:run-local": "tsx scripts/engineering-run-local.ts --input output/engineering-simulate --out output/engineering-run-local",
    "coding-agent:drill": "tsx scripts/coding-agent-receipt-drill.ts --out output/coding-agent-receipt-drill",
    "localization:drill": "tsx scripts/localization-drill.ts --out output/localization-drill",
    "executor:drill": "tsx scripts/executor-contract-drill.ts --out output/executor-contract-drill",
    "sandbox:capabilities": "tsx scripts/sandbox-capability-drill.ts --out output/sandbox-capability-drill",
    "security:red-team": "tsx scripts/security-red-team-drill.ts --out output/security-red-team-drill",
    "runner-auth:drill": "tsx scripts/runner-auth-drill.ts --out output/runner-auth-drill",
    "production:boundary": "tsx scripts/production-boundary-drill.ts --verification output/rehearsal-drill/release-verification-production-latest.json --out output/verification/production-boundary-latest.json",
    "verification:manifest": "tsx scripts/verification-manifest.ts --coding-agent-dispatch output/coding-agent-dispatch-drill/summary.json --coding-agent-simulation output/coding-agent-dispatch-simulation/summary.json --coding-agent-runner-manifest output/coding-agent-runner-manifest/summary.json --coding-agent-runner-invocation output/coding-agent-runner-invocation/summary.json --coding-agent-runner-intake output/coding-agent-runner-intake-audit/summary.json --coding-agent-runner-self-test output/coding-agent-runner-self-test/summary.json --coding-agent-runner-lease output/coding-agent-runner-lease/summary.json --coding-agent-sandbox-runner output/coding-agent-sandbox-runner/summary.json --coding-agent-engineering-self-simulation output/coding-agent-engineering-self-simulation/summary.json --coding-agent-report output/coding-agent-receipt-drill/summary.json --localization-drill output/localization-drill/summary.json --executor-contract-drill output/executor-contract-drill/summary.json --sandbox-capability-drill output/sandbox-capability-drill/summary.json --security-red-team-drill output/security-red-team-drill/summary.json --runner-auth-drill output/runner-auth-drill/summary.json --production-boundary-drill output/verification/production-boundary-latest.json --release-verification output/rehearsal-drill/release-verification-latest.json --out output/verification/verification-manifest-latest.json",
    "release:verify": "npm run localization:drill && npm run executor:drill && npm run sandbox:capabilities && npm run security:red-team && npm run runner-auth:drill && npm run coding-agent:dispatch && npm run coding-agent:simulate && npm run coding-agent:runner-manifest && npm run coding-agent:runner-invocation && npm run coding-agent:runner-intake && npm run coding-agent:runner-self-test && npm run coding-agent:runner-lease && npm run coding-agent:sandbox-runner && npm run coding-agent:engineering-sim && npm run coding-agent:drill && npm run rehearsal:drill && tsx scripts/verify-release.ts --report output/rehearsal-drill/release-rehearsal-latest.json --out output/rehearsal-drill/release-verification-latest.json && npm run production:boundary && npm run verification:manifest",
    "release:verify:production": "tsx scripts/verify-release.ts --report output/rehearsal-drill/release-rehearsal-latest.json --require-production --out output/rehearsal-drill/release-verification-production-latest.json",
    "verify:all": "tsx scripts/verify-all.ts",
    "ci:open-source": "npm run open-source:mvp-check && npm run test && git diff --check",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.0",
    "vite": "^7.1.0",
    "vitest": "^3.2.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
