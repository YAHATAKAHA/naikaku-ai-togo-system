# Open-source example only. These names are placeholders, not project-supplied tokens.
# Do not commit real tokens or API keys.
# Each operator supplies their own provider keys and local gateway tokens.
# Frontend never persists raw secrets. Production connectors should resolve these
# server-side or from a local encrypted vault.
NAIKAKU_OPENAI_API_KEY=
NAIKAKU_ANTHROPIC_API_KEY=
NAIKAKU_OPENROUTER_API_KEY=
NAIKAKU_GOOGLE_API_KEY=
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-turbo
NAIKAKU_LOCAL_GATEWAY_TOKEN=
NAIKAKU_SANDBOX_GATEWAY_TOKEN=
NAIKAKU_MEMORY_GATEWAY_TOKEN=
NAIKAKU_LOCAL_GATEWAY_URL=http://localhost:8787
NAIKAKU_SANDBOX_GATEWAY_URL=http://localhost:8790
VITE_NAIKAKU_GATEWAY_URL=http://127.0.0.1:8787
NAIKAKU_GATEWAY_HOST=127.0.0.1
NAIKAKU_GATEWAY_PORT=8787
NAIKAKU_CORS_ORIGIN=http://127.0.0.1:5173
NAIKAKU_RUNNER_TOKEN=
NAIKAKU_LEDGER_DIR=.naikaku-data
